---
import { GameBoyMode } from '@/components/react/GameBoyMode';
import { DEFAULT_LANGUAGE } from '@/i18n/config';
import { getTranslation } from '@/i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const defaultT = getTranslation(DEFAULT_LANGUAGE);

const {
  title = defaultT.meta.title,
  description = defaultT.meta.description,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://xiza.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Manuel Fajardo',
  alternateName: 'Xiza',
  jobTitle: 'Software Engineer',
  url: siteUrl,
  sameAs: ['https://github.com/xiza', 'https://linkedin.com/in/xiza'],
};
---

<!doctype html>
<html lang={DEFAULT_LANGUAGE} style="overflow-x: clip;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Manuel Fajardo (Xiza)" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:site_name" content="Xiza.dev" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Press Start 2P (pixel font) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Prevent flash of wrong theme/language -->
    <script is:inline>
      if (localStorage.getItem('gameboy-mode') === 'on') {
        document.documentElement.setAttribute('data-gameboy', '');
      }
      (function() {
        var lang = localStorage.getItem('language');
        if (lang === 'en' || lang === 'es') {
          document.documentElement.lang = lang;
        }
      })();
    </script>
  </head>
  <body class="crt-overlay min-h-screen bg-bg text-text">
    <slot />
    <GameBoyMode client:load />
  </body>
</html>
