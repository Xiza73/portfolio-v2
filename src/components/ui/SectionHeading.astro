---
interface Props {
  tag: string;
  title: string;
}

const { tag, title } = Astro.props;
---

<div class="mb-8 sm:mb-10 md:mb-12">
  <div class="mb-3 inline-block bg-primary px-3 py-1.5 pixel-corner sm:mb-4 sm:px-4 sm:py-2">
    <span class="pixel-text text-[10px] text-text-dark sm:text-xs md:text-sm">{tag}</span>
  </div>
  <h2 class="pixel-text text-xl text-primary sm:text-2xl md:text-3xl lg:text-4xl">{title}</h2>
</div>
