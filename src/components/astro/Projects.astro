---
import { AnimatedSection } from '@/components/react/AnimatedSection';
import ProjectCard from '@/components/ui/ProjectCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getProjects } from '@/data/projects';
import { type Language } from '@/i18n/config';

interface Props {
  t: {
    tag: string;
    title: string;
    code: string;
    demo: string;
  };
  lang: Language;
}

const { t, lang } = Astro.props;
const projects = getProjects(lang);
---

<section id="projects" class="py-16 px-4 sm:py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    <AnimatedSection client:visible>
      <SectionHeading tag={t.tag} title={t.title} />
    </AnimatedSection>

    <div class="grid gap-4 sm:gap-6 md:grid-cols-2 lg:gap-8">
      {projects.map((project, index) => (
        <AnimatedSection client:visible delay={index * 0.1} className="h-full">
          <ProjectCard project={project} demoLabel={t.demo} />
        </AnimatedSection>
      ))}
    </div>
  </div>
</section>
