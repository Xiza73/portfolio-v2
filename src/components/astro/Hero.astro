---
import { AnimatedSection } from '@/components/react/AnimatedSection';
import { PixelCharacter } from '@/components/react/PixelCharacter';
import SocialLink from '@/components/ui/SocialLink.astro';
import { socialLinks } from '@/data/social-links';
---

<section
  id="about"
  class="flex min-h-screen items-center justify-center px-4 pt-16 sm:px-6 sm:pt-20 lg:px-8"
>
  <div class="mx-auto w-full max-w-6xl">
    <div class="grid items-center gap-8 sm:gap-10 md:grid-cols-2 md:gap-12">
      <!-- Left Column - Text -->
      <AnimatedSection client:visible direction="left">
        <div class="space-y-4 text-center sm:space-y-5 md:space-y-6 md:text-left">
          <div class="inline-block bg-primary px-3 py-1.5 pixel-corner sm:px-4 sm:py-2">
            <span class="pixel-text text-[10px] text-text-dark sm:text-xs md:text-sm"
              >HELLO_WORLD.EXE</span
            >
          </div>

          <h1
            class="pixel-text text-2xl leading-tight text-primary sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
          >
            SOFTWARE<br />ENGINEER
          </h1>

          <p class="pixel-text text-[10px] leading-relaxed text-accent sm:text-xs md:text-sm">
            Crafting digital experiences with clean code and pixel-perfect precision. Specializing in
            full-stack development with a passion for creating innovative solutions.
          </p>

          <!-- Social Links -->
          <div class="flex justify-center gap-3 pt-2 sm:gap-4 sm:pt-4 md:justify-start">
            {socialLinks.map((link) => (
              <SocialLink href={link.href} label={link.label} icon={link.icon} />
            ))}
          </div>

          <!-- CTA -->
          <div class="pt-1 sm:pt-2">
            <a
              href="#projects"
              class="inline-block bg-primary px-5 py-3 transition-colors hover:bg-accent pixel-corner sm:px-8 sm:py-4 group"
            >
              <span class="pixel-text text-[10px] text-text-dark sm:text-xs md:text-sm"
                >VIEW_PROJECTS</span
              >
            </a>
          </div>
        </div>
      </AnimatedSection>

      <!-- Right Column - Pixel Art Character -->
      <PixelCharacter client:visible />
    </div>
  </div>
</section>
