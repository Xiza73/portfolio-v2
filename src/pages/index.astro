---
import '@/styles/global.css';

import { ContactSection } from '@/components/react/ContactSection';
import { FooterSection } from '@/components/react/FooterSection';
import { Header } from '@/components/react/Header';
import { HeroSection } from '@/components/react/HeroSection';
import { ProjectsSection } from '@/components/react/ProjectsSection';
import { SkillsSection } from '@/components/react/SkillsSection';
import { ActiveNavHighlight } from '@/components/react/ActiveNavHighlight';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout>
  <Header client:load />

  <main class="overflow-x-clip">
    <HeroSection client:load />
    <ProjectsSection client:visible />
    <SkillsSection client:visible />
    <ContactSection client:idle />
  </main>

  <FooterSection client:idle />
  <ActiveNavHighlight client:idle sectionIds={['about', 'projects', 'skills', 'contact']} />
</BaseLayout>
