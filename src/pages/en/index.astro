---
import '@/styles/global.css';

import Contact from '@/components/astro/Contact.astro';
import Footer from '@/components/astro/Footer.astro';
import Header from '@/components/astro/Header.astro';
import Hero from '@/components/astro/Hero.astro';
import Projects from '@/components/astro/Projects.astro';
import Skills from '@/components/astro/Skills.astro';
import { ActiveNavHighlight } from '@/components/react/ActiveNavHighlight';
import { getNavItems } from '@/data/navigation';
import { getTranslation } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = 'en' as const;
const t = getTranslation(lang);
const navItems = getNavItems(t.nav);
---

<BaseLayout title={t.meta.title} description={t.meta.description} lang={lang}>
  <Header navItems={navItems} lang={lang} switchLabel={t.language.switch_label} />

  <main>
    <Hero t={t.hero} />
    <Projects t={t.projects} />
    <Skills t={t.skills} />
    <Contact t={t.contact} />
  </main>

  <Footer t={t.footer} />
  <ActiveNavHighlight client:idle sectionIds={['about', 'projects', 'skills', 'contact']} />
</BaseLayout>
